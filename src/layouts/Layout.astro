---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Link, GlobalInjections, TopHtmlConfig, SlotConfig } from "../types";

interface Props {
  title: string;
  links: Link[];
  injections?: GlobalInjections;
}

const { title, links, injections } = Astro.props;

const topHtmlRaw = injections?.top_html;
let topHtmlConfig: TopHtmlConfig | null = null;

if (topHtmlRaw) {
  if (typeof topHtmlRaw === 'string') {
    topHtmlConfig = { html: topHtmlRaw, is_active: true, close_button: true };
  } else {
    topHtmlConfig = topHtmlRaw;
  }
}

const showTopHtml = topHtmlConfig?.is_active && topHtmlConfig?.html;

const footerSlotRaw = injections?.footer_slot;
const showFooterSlot = typeof footerSlotRaw === 'string' ? !!footerSlotRaw : (footerSlotRaw?.is_active && footerSlotRaw?.html);
const footerSlotHtml = typeof footerSlotRaw === 'string' ? footerSlotRaw : footerSlotRaw?.html;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="NSDC MEC Website" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://ik.imagekit.io" />
    <title>{title}</title>

    <ClientRouter />
    <script is:inline>
      const getTheme = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return "system";
      };

      const applyTheme = (theme) => {
        const root = document.documentElement;
        root.classList.remove("light", "dark");
        if (theme === "dark") root.classList.add("dark");
        if (theme === "light") root.classList.add("light");
      };

      applyTheme(getTheme());

      document.addEventListener("astro:after-swap", () =>
        applyTheme(getTheme()),
      );
    </script>
  </head>
  <body class="antialiased min-h-screen flex flex-col overflow-x-hidden">
    {showTopHtml && (
      <div id="top-injection-banner" class="relative w-full z-[60]">
        <div set:html={topHtmlConfig.html} />
        {topHtmlConfig.should_close && (
          <button
            aria-label="Close Announcement"
            onclick="document.getElementById('top-injection-banner').remove()"
            class="absolute top-2 right-2 p-1 bg-black/10 hover:bg-black/20 text-current rounded-full transition-colors cursor-pointer z-50"
          >
             <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        )}
      </div>
    )}
    
    <div transition:persist="header" class="sticky top-0 z-50 w-full">
      <Header links={links} />
    </div>

    <main class="flex-grow w-full" transition:name="main">
      <slot />
    </main>

    {showFooterSlot && <div set:html={footerSlotHtml} />}
    <Footer links={links} />
  </body>
</html>
