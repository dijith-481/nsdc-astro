---
import Layout from "../../layouts/Layout.astro";
import TeamMemberCard from "../../components/TeamMemberCard.astro";
import { dataService } from "../../lib/data-service";

const data = await dataService.getInitialData();
const { year } = Astro.params;

const currentTeam = data.teams.find((t) => t.id === year);
if (!currentTeam) {
  const latest = data.teams[0]?.id;
  if (latest) return Astro.redirect(`/teams/${latest}`);
  return Astro.redirect("/404");
}
const sortedMembers = currentTeam.members.sort(
  (a, b) => a.priority - b.priority,
);

const allYears = data.teams.map((t) => ({ id: t.id, title: t.title }));
---

<Layout title={`${currentTeam.title} | NSDC MEC`} links={data.links}>
  <div class="bg-bg-0 text-fg-0 transition-colors duration-300">
    <section class="py-16 lg:py-20">
      <div class="px-4 mb-8">
        <div class="flex justify-between items-center mb-10">
          <h2
            class="text-3xl md:text-4xl font-bold font-sans text-fg-0"
            transition:name="team-page-title"
          >
            Our Team
          </h2>

          {
            allYears.map((y) => (
              <a
                id={`year-link-${y.id}`}
                href={`/teams/${y.id}`}
                class="hidden"
              />
            ))
          }
          <div class="relative" transition:name="team-year-selector">
            <select
              onchange="document.getElementById('year-link-' + this.value).click()"
              class="appearance-none bg-bg-1 pl-4 pr-10 py-2 border border-bg-2 text-sm font-semibold text-fg-0 focus:ring-2 focus:ring-primary focus:outline-none cursor-pointer hover:border-fg-1 transition-colors"
              aria-label="Select Team Year"
            >
              {
                allYears.map((y) => (
                  <option value={y.id} selected={y.id === year}>
                    {y.title}
                  </option>
                ))
              }
            </select>
            <div
              class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-fg-1"
            >
              <svg
                class="fill-current h-4 w-4"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                ><path
                  d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"
                ></path></svg
              >
            </div>
          </div>
        </div>

        <div
          class="team-grid pl-2 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 w-full border-fg-0/20"
        >
          {
            sortedMembers.map((member) => (
              <div class="team-cell  w-full h-full flex flex-col">
                <div class="flex flex-row h-full w-full">
                  <div class="card-content h-full w-full  border-r border-b border-fg-0/20  relative z-10">
                    {member ? (
                      <TeamMemberCard member={member} />
                    ) : (
                      <div class="w-full h-full  bg-bg-0/20" />
                    )}
                  </div>
                  <div class="right-spacer w-4 h-full border-r border-b border-fg-0/20" />
                </div>

                <div class="flex flex-row h-4 w-full">
                  <div class="bottom-spacer   w-full h-4    border-r border-b border-fg-0/20  z-0" />
                  <div class="bottom-right-spacer   w-4 h-4  bg-fg-0/20  hover:bg-fg-0 transition-colors duration-300   border-fg-0/20  z-0" />
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
