---
// src/pages/report/[id].astro
import Layout from "../../layouts/Layout.astro";
import { dataService } from "../../lib/data-service";
import type { Event } from "../../types";

export async function getStaticPaths() {
  const data = await dataService.getInitialData();
  const reports = data.events; // Or filter for specific reports if needed

  return reports.map((report) => {
    return {
      params: { id: report.id },
      props: { report, links: data.links },
    };
  });
}

interface Props {
  report: Event;
  links: any;
}

const { report, links } = Astro.props;

const formattedDate = new Date(report.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={report.title} links={links}>
  <article class="max-w-4xl mx-auto container px-4 py-12 md:py-20 bg-[#FAF9F6]">
    <div class="border-b border-gray-200 pb-8 mb-8">
      <h1
        class="text-4xl md:text-6xl font-serif font-bold text-gray-900 leading-tight"
      >
        {report.title}
      </h1>
      <p class="mt-4 text-lg text-gray-500">
        Published on {formattedDate}
      </p>
    </div>

    <figure class="my-8">
      <img
        src={report.img}
        alt={report.title}
        class="w-full h-auto object-cover rounded-lg shadow-md"
      />
    </figure>

    <div class="prose prose-lg max-w-none text-gray-800 leading-relaxed">
      {report.desc.split("\n").map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </article>
</Layout>
