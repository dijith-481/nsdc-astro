---
import Layout from "../layouts/Layout.astro";
import { dataService } from "../lib/data-service";
import ResourcesComponent from "../components/Resources.astro";
import type { Resource } from "../types";

const data = await dataService.getInitialData();

if (!data) {
  throw new Error("Failed to load data for the resources page.");
}

// Group resources by type
const groupedResources = data.resources.reduce((acc, resource) => {
  const type = resource.resource_type || "Other";
  if (!acc[type]) {
    acc[type] = [];
  }
  acc[type].push(resource);
  return acc;
}, {} as Record<string, Resource[]>);

// Order of sections (Projects first, then others sorted alphabetically or fixed)
const predefinedOrder = ["project", "publication", "journal", "resource"];
const sortedTypes = Object.keys(groupedResources).sort((a, b) => {
    const idxA = predefinedOrder.indexOf(a.toLowerCase());
    const idxB = predefinedOrder.indexOf(b.toLowerCase());
    if (idxA !== -1 && idxB !== -1) return idxA - idxB;
    if (idxA !== -1) return -1;
    if (idxB !== -1) return 1;
    return a.localeCompare(b);
});
---

<Layout title="Resources | NSDC MEC" links={data.links} injections={data.config.injections}>
    <div class=" bg-bg-0 min-h-screen">

      {sortedTypes.map((type) => (
        <ResourcesComponent 
            title={type.charAt(0).toUpperCase() + type.slice(1) + (type.endsWith('s') ? '' : 's')} 
            resources={groupedResources[type]} 
        />
      ))}

      {sortedTypes.length === 0 && (
         <div class="container mx-auto px-4 py-12 text-center">
            <p class="text-fg-1">No resources found.</p>
         </div>
      )}
    </div>
</Layout>
