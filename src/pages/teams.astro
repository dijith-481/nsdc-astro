---
// src/pages/teams.astro
import Layout from "../layouts/Layout.astro";
import { dataService } from "../lib/data-service";
import Team from "../components/Team";
import TeamPreview from "../components/TeamPreview.astro";

// Fetch data at build time
const data = await dataService.getInitialData();

if (!data) {
  throw new Error("Failed to load data for the teams page.");
}
---

<Layout title="Our Team | NSDC MEC" links={data.links}>
  <div class="bg-white text-black">
    <div class="w-full">
      <!--
        The Team component requires JavaScript to handle the year selection dropdown.
        `client:load` ensures the component is interactive as soon as the page loads.
      -->
      <Team
        teams={data.teams}
        client:load
      />
    </div>
      <TeamPreview imageUrl={data.teamsPreview.src}  />
  </div>
</Layout>
