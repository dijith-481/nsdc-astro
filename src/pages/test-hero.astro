---
import Layout from "../layouts/Layout.astro";
import { dataService } from "../lib/data-service";
import Hero from "../components/Hero.astro";
import type { Event, HeroEventConfig } from "../types";

const data = await dataService.getInitialData();

// Create a fake event for testing
const now = new Date();
const startTime = new Date(now.getTime() + 1 * 60 * 1000); // starts in 1 minute
const endTime = new Date(now.getTime() + 2 * 60 * 1000);   // ends in 2 minutes

const fakeEvent: Event = {
  id: 999,
  title: "⚡ Live API Test Event",
  description: "Testing live script execution in Hero background.",
  image_url: "https://images.unsplash.com/photo-1518546305927-5a555bb7020d?q=80&w=1000&auto=format&fit=crop",
  date: startTime.toLocaleDateString(),
  status: "upcoming",
  venue: "Blockchain",
  event_type: "Live Demo",
  link: "https://google.com",
  priority: 1,
  report_url: "/reports",
  custom_html: null,
  metadata: {
    hero_config: {
      start_date: startTime.toISOString(),
      end_date: endTime.toISOString(),
      show_in_hero: true,
      before: 5, 
      after: 5,  
      
      // Default fallback
      bg_type: "image",
      bg_value: "https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=1000&auto=format&fit=crop",
      
      // State specific configs
      before_config: {
        bg: {
            type: 'image',
            value: 'https://images.unsplash.com/photo-1621416894569-0f39ed31d247?q=80&w=1000&auto=format&fit=crop'
        },
        link: "https://example.com/register",
        hide_details: false
      },
      
      ongoing_config: {
        bg: {
            type: 'html',
            value: `
            <div style="width:100%; height:100%; background: #0d1117; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #fff; font-family: monospace;">
                <h3 style="font-size: 1.5rem; margin-bottom: 1rem; color: #f2a900;">LIVE BITCOIN PRICE</h3>
                <div id="btc-price" style="font-size: 4rem; font-weight: bold;">Loading...</div>
                <div style="font-size: 0.8rem; opacity: 0.6; margin-top: 1rem;">Powered by CoinGecko API</div>
            </div>
            <script>
                console.log("🚀 Live Script Started!");
                
                function fetchPrice() {
                    fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=usd')
                        .then(res => res.json())
                        .then(data => {
                            const price = data.bitcoin.usd;
                            const el = document.getElementById('btc-price');
                            if(el) {
                                el.innerText = '$' + price.toLocaleString();
                                el.style.color = '#00ff88';
                            }
                        })
                        .catch(err => {
                            console.error(err);
                            const el = document.getElementById('btc-price');
                            if(el) el.innerText = 'API Error';
                        });
                }

                // Initial fetch
                fetchPrice();
                
                // Poll every 5 seconds
                const interval = setInterval(fetchPrice, 5000);
            </script>
            `
        },
        link: "https://example.com/join",
        hide_details: true // Hide details to show the custom HTML fully
      },
      
      after_config: {
        bg: {
            type: 'image',
            value: 'https://images.unsplash.com/photo-1639322537228-f710d846310a?q=80&w=1000&auto=format&fit=crop'
        },
        link: "https://example.com/feedback",
        hide_details: false
      }
    }
  }
};

// Pass as array to trigger client-side logic
const heroEvents = [fakeEvent];
---

<Layout title="Live API Test | NSDC MEC" links={data.links} injections={data.config.injections}>
  <Hero 
    config={data.config.hero} 
    main={data.config.heroMain} 
    announcements={data.announcements}
    heroEvents={heroEvents}
  />
  
  <div class="p-8 bg-bg-1 border-t border-bg-2">
    <h2 class="text-xl font-bold text-fg-0 mb-4">Test Controller Info</h2>
    <div class="grid md:grid-cols-2 gap-8">
        <ul class="space-y-2 text-fg-1 font-mono text-sm">
            <li>Current Time: {now.toISOString()}</li>
            <li>Event Start: {startTime.toISOString()} (T-minus 1m)</li>
            <li>Event End: {endTime.toISOString()} (T-plus 1m from start)</li>
            <li class="font-bold text-primary">
                Client-side logic is now responsible for activating this event.
            </li>
        </ul>
        <div class="text-sm text-fg-1 space-y-2">
            <p><strong>Transitions to watch:</strong></p>
            <ul class="list-disc pl-5">
                <li><span class="text-blue-400">Before:</span> Image BG, Details Visible</li>
                <li><span class="text-red-400">Ongoing:</span> <strong>HTML BG (Live BTC)</strong>, Details Hidden</li>
                <li><span class="text-gray-400">After:</span> Image BG, Details Visible</li>
            </ul>
        </div>
    </div>
  </div>
</Layout>
