---
import Layout from "../layouts/Layout.astro";
import { dataService } from "../lib/data-service";

import Hero from "../components/Hero";
import About from "../components/About.astro";
import Events from "../components/Events";
import Projects from "../components/Projects.astro";
import Resources from "../components/Resources.astro";
import TeamPreview from "../components/TeamPreview.astro";

const data = await dataService.getInitialData();
if (!data) {
  throw new Error("Failed to load initial data for the homepage.");
}
---

<Layout title="NSDC MEC" links={data.links}>
  <Hero
    content={data.heroContent}
    announcements={data.announcements}
    client:load
  />
  <About content={data.about} />
  <Events events={data.events} isPreview={true} client:load />
  <Projects projects={data.projects} isPreview={true} />
  <Resources resources={data.resources} isPreview={true} />
  <TeamPreview imageUrl={data.teamsPreview.src} isPreview={true} />
</Layout>
